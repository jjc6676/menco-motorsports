---
// Menco Motorsports — SVG Logo
// Intentionally styled: Bebas Neue, white text, red accent line
---
<a href="/" class="flex items-center gap-3 group" aria-label="Menco Motorsports — Home">
  <svg
    width="220"
    height="48"
    viewBox="0 0 220 48"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <!-- Red accent bar left -->
    <rect x="0" y="8" width="4" height="32" fill="#cc0000" />
    <!-- Main wordmark -->
    <text
      x="12"
      y="28"
      font-family="'Bebas Neue', Impact, sans-serif"
      font-size="26"
      fill="#f5f5f5"
      letter-spacing="2"
    >MENCO</text>
    <text
      x="12"
      y="44"
      font-family="'Bebas Neue', Impact, sans-serif"
      font-size="14"
      fill="#cc0000"
      letter-spacing="4"
    >MOTORSPORTS</text>
  </svg>
</a>
