---
---
<footer class="bg-brand-dark border-t border-white/10 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand column -->
      <div>
        <p class="font-heading text-2xl text-brand-light tracking-widest mb-1">MENCO</p>
        <p class="font-heading text-sm text-brand-red tracking-widest mb-1">MOTORSPORTS</p>
        <span class="block w-8 h-px bg-brand-red mb-4"></span>
      </div>

      <!-- Quick links -->
      <div>
        <p class="font-heading text-lg text-brand-light tracking-widest mb-1">QUICK LINKS</p>
        <span class="block w-8 h-px bg-brand-red mb-4"></span>
        <ul class="space-y-2">
          {[
            { href: '/', label: 'Home' },
            { href: '/services', label: 'Services' },
            { href: '/about', label: 'About Us' },
            { href: '/gallery', label: 'Gallery' },
            { href: '/shop', label: 'Shop' },
            { href: '/contact', label: 'Contact' },
          ].map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="font-body text-sm text-brand-light hover:text-brand-red transition-colors"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <p class="font-heading text-lg text-brand-light tracking-widest mb-1">CONTACT</p>
        <span class="block w-8 h-px bg-brand-red mb-4"></span>
        <ul class="space-y-3 font-body text-sm text-brand-light">
          <li>
            <a href="tel:3372886226" class="hover:text-brand-red transition-colors">(337) 288-6226</a>
          </li>
          <li>
            <a href="mailto:tucksdieselservices@yahoo.com" class="hover:text-brand-red transition-colors">tucksdieselservices@yahoo.com</a>
          </li>
          <li>Lafayette, LA 70507</li>
          <li>Mon-Fri: 7am-5pm<br />Sat: By appointment</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-body text-xs text-brand-light/60">
        &copy; {new Date().getFullYear()} Menco Motorsports. All rights reserved.
      </p>
      <p class="font-body text-xs text-brand-light/40">
        Built by <a href="https://thechoplingroup.com" class="hover:text-brand-light/70 transition-colors" rel="noopener">The Choplin Group</a>
      </p>
    </div>
  </div>
</footer>
