---
---
<footer class="bg-brand-dark border-t border-white/10 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand column -->
      <div>
        <p class="font-heading text-2xl text-brand-light tracking-widest mb-1">MENCO</p>
        <p class="font-heading text-sm text-brand-red tracking-widest mb-4">MOTORSPORTS</p>
        <p class="font-body text-brand-gray text-sm leading-relaxed">
          Lafayette's diesel performance and repair specialists. Powerstroke, Duramax, Cummins — we keep working trucks working.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <p class="font-heading text-lg text-brand-light tracking-widest mb-4">QUICK LINKS</p>
        <ul class="space-y-2">
          {[
            { href: '/', label: 'Home' },
            { href: '/services', label: 'Services' },
            { href: '/about', label: 'About Us' },
            { href: '/gallery', label: 'Gallery' },
            { href: '/shop', label: 'Shop' },
            { href: '/contact', label: 'Contact' },
          ].map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="font-body text-sm text-brand-gray hover:text-brand-red transition-colors"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <p class="font-heading text-lg text-brand-light tracking-widest mb-4">CONTACT</p>
        <ul class="space-y-3 font-body text-sm text-brand-gray">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:3372886226" class="hover:text-brand-red transition-colors">(337) 288-6226</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:tucksdieselservices@yahoo.com" class="hover:text-brand-red transition-colors">tucksdieselservices@yahoo.com</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Lafayette, LA 70507</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-brand-red mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Mon-Fri: 7am-5pm<br />Sat: By appointment</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-body text-xs text-brand-gray/60">
        &copy; {new Date().getFullYear()} Menco Motorsports. All rights reserved.
      </p>
      <p class="font-body text-xs text-brand-gray/40">
        Built by <a href="https://thechoplingroup.com" class="hover:text-brand-gray/70 transition-colors" rel="noopener">The Choplin Group</a>
      </p>
    </div>
  </div>
</footer>
