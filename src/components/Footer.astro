<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">MENCO <span>MOTORSPORTS</span></a>
      <p>Locally owned mechanic shop in Lafayette, LA<br>specializing in diesel repair and performance.</p>
      <a href="https://www.facebook.com/profile.php?id=61558910277885" target="_blank" rel="noopener noreferrer" class="footer-social" aria-label="Visit our Facebook page">Facebook</a>
    </div>
    <div class="footer-contact">
      <a href="tel:3372886226" class="footer-phone">(337) 288-6226</a>
      <a href="mailto:tucksdieselservices@yahoo.com">tucksdieselservices@yahoo.com</a>
      <p class="footer-address">Lafayette, LA 70507</p>
      <p class="footer-hours">Always Open</p>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} Menco Motorsports. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-primary);
    border-top: 2px solid var(--accent);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: 3px;
    color: var(--text-primary);
    text-decoration: none;
    text-transform: uppercase;
    display: block;
    margin-bottom: var(--space-sm);
  }
  .footer-logo span { color: var(--accent-accessible); }
  .footer-logo:hover { color: var(--text-primary); }
  .footer-brand p {
    color: var(--text-dim);
    font-size: 0.8125rem;
    line-height: 1.6;
  }
  .footer-social {
    display: inline-block;
    margin-top: var(--space-sm);
    color: var(--accent-accessible);
    font-weight: 600;
    font-size: 0.875rem;
  }
  .footer-contact {
    text-align: right;
  }
  .footer-phone {
    display: block;
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--accent-accessible);
    margin-bottom: var(--space-xs);
    font-variant-numeric: tabular-nums;
  }
  .footer-contact a {
    display: block;
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: var(--space-xs);
  }
  .footer-address, .footer-hours {
    color: var(--text-dim);
    font-size: 0.875rem;
    margin-top: var(--space-sm);
  }
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: var(--space-md) 0;
  }
  .footer-bottom p {
    font-size: 0.75rem;
    color: var(--text-dim);
    text-align: center;
  }

  @media (max-width: 639px) {
    .footer-inner {
      flex-direction: column;
      gap: var(--space-lg);
    }
    .footer-contact { text-align: left; }
  }
</style>
