---
import '@fontsource/barlow/400.css';
import '@fontsource/barlow/500.css';
import '@fontsource/barlow/700.css';
import '@fontsource/barlow-condensed/700.css';
import '@fontsource/barlow-condensed/800.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Locally owned diesel repair and performance shop in Lafayette, LA. Fuel systems, diagnostics, performance upgrades, and preventative maintenance. Done right the first time.',
  ogImage = '/images/og-default.jpg'
} = Astro.props;

const siteTitle = title === 'Home' ? 'Menco Motorsports | Diesel Repair & Performance | Lafayette, LA' : `${title} | Menco Motorsports`;
const canonicalUrl = new URL(Astro.url.pathname, 'https://mencomotorsports.com');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteTitle}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonicalUrl.toString()}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={siteTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:url" content={canonicalUrl.toString()}>
  <meta property="og:locale" content="en_US">

  <!-- Fonts loaded via fontsource -->

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AutoRepair",
    "name": "Menco Motorsports",
    "description": "Locally owned diesel repair and performance shop specializing in fuel systems, diagnostics, and performance upgrades.",
    "url": "https://mencomotorsports.com",
    "telephone": "+13372886226",
    "email": "tucksdieselservices@yahoo.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Lafayette",
      "addressRegion": "LA",
      "postalCode": "70507",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 30.2241,
      "longitude": -92.0198
    },
    "openingHours": "Mo-Su 00:00-23:59",
    "priceRange": "$$",
    "image": "https://mencomotorsports.com/images/og-default.jpg",
    "sameAs": [
      "https://www.facebook.com/profile.php?id=61558910277885"
    ],
    "serviceArea": {
      "@type": "GeoCircle",
      "geoMidpoint": {
        "@type": "GeoCoordinates",
        "latitude": 30.2241,
        "longitude": -92.0198
      },
      "geoRadius": "50000"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Diesel Repair Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fuel System Repair & Upgrades" }},
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Diesel Diagnostics & Repair" }},
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Performance Upgrades" }},
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Preventative Maintenance" }}
      ]
    }
  })} />
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
</body>
</html>
