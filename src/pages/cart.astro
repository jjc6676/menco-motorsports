---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cart" description="Review your order and reserve for pickup at Menco Motorsports.">
  <section class="bg-gradient-to-b from-brand-dark to-brand-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-red">Your Order</p>
      <h1 class="section-heading mt-4">Your Cart</h1>
      <span class="red-accent-line"></span>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div id="cart-empty" class="text-center py-20" style="display:none;">
        <p class="font-heading text-3xl text-brand-light uppercase">Cart is empty</p>
        <p class="mt-4 text-brand-gray">Add some gear from the shop.</p>
        <a href="/shop" class="btn-red inline-block mt-8">Browse Shop</a>
      </div>

      <div id="cart-content" style="display:none;">
        <div id="cart-items"></div>

        <div class="bg-brand-dark border border-white/10 mt-8 p-6 sm:p-8">
          <div class="flex items-center justify-between">
            <div>
              <p class="font-heading text-2xl text-brand-light uppercase">Total</p>
              <p class="mt-1 text-sm text-brand-gray">Pay when you pick up at the shop. No payment required now.</p>
            </div>
            <p id="cart-total-price" class="font-heading text-4xl text-brand-light">$0.00</p>
          </div>
        </div>

        <div class="bg-brand-dark border border-white/10 mt-8 p-6 sm:p-8">
          <p class="font-heading text-2xl text-brand-light uppercase">Your Info</p>
          <span class="red-accent-line"></span>
          <p class="text-brand-gray text-sm mb-6">We'll text or call when your order is ready for pickup.</p>

          <form id="checkout-form" class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">Name *</span>
              <input type="text" id="checkout-name" required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red" />
            </label>
            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">Phone *</span>
              <input type="tel" id="checkout-phone" placeholder="(337) 555-0123" required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition placeholder:text-brand-gray/60 focus:border-brand-red focus:ring-1 focus:ring-brand-red" />
            </label>
            <div style="display:none;">
              <input type="text" id="checkout-website" tabindex="-1" autocomplete="off" />
            </div>
            <div class="sm:col-span-2 flex flex-col gap-4 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-sm text-brand-gray">Prefer to call? <a href="tel:3372886226" class="text-brand-red hover:text-brand-redHot">(337) 288-6226</a></p>
              <button type="submit" id="submit-btn" class="btn-red w-full sm:w-auto text-center">Place Order</button>
            </div>
            <div id="form-status" class="sm:col-span-2 font-body text-sm"></div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { getCartItems, removeFromCart, updateQuantity, clearCart, getCartTotal } from '../lib/cart';

  function formatPrice(cents: number) {
    return '$' + (cents / 100).toFixed(2);
  }

  function renderCart() {
    const items = getCartItems();
    const emptyEl = document.getElementById('cart-empty')!;
    const contentEl = document.getElementById('cart-content')!;
    const itemsEl = document.getElementById('cart-items')!;
    const totalEl = document.getElementById('cart-total-price')!;

    if (items.length === 0) {
      emptyEl.style.display = 'block';
      contentEl.style.display = 'none';
      return;
    }

    emptyEl.style.display = 'none';
    contentEl.style.display = 'block';

    itemsEl.innerHTML = items.map(item => `
      <div class="bg-[#111] border border-[rgba(255,255,255,0.1)] mb-3 p-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <p class="font-heading text-xl text-[#f5f5f5] uppercase">${item.name}</p>
          ${item.size ? `<span class="text-xs uppercase tracking-[0.2em] text-[#999]">Size: ${item.size}</span>` : ''}
          <span class="ml-2 text-sm text-[#999]">${formatPrice(item.price)} each</span>
        </div>
        <div class="flex items-center gap-5">
          <div class="flex items-center border border-[rgba(255,255,255,0.1)]">
            <button class="qty-btn w-9 h-9 flex items-center justify-center bg-[#1a1a1a] text-[#f5f5f5] text-lg hover:bg-[#cc0000] hover:text-white transition-colors" data-action="decrease" data-id="${item.id}" data-size="${item.size || ''}">−</button>
            <span class="w-10 h-9 flex items-center justify-center text-[#f5f5f5] font-medium bg-[#0a0a0a] tabular-nums">${item.quantity}</span>
            <button class="qty-btn w-9 h-9 flex items-center justify-center bg-[#1a1a1a] text-[#f5f5f5] text-lg hover:bg-[#cc0000] hover:text-white transition-colors" data-action="increase" data-id="${item.id}" data-size="${item.size || ''}">+</button>
          </div>
          <p class="font-heading text-2xl text-[#cc0000] min-w-[80px] text-right tabular-nums">${formatPrice(item.price * item.quantity)}</p>
          <button class="remove-btn text-[#555] hover:text-[#cc0000] transition-colors text-lg p-2" data-id="${item.id}" data-size="${item.size || ''}" aria-label="Remove ${item.name}">✕</button>
        </div>
      </div>
    `).join('');

    totalEl.textContent = formatPrice(getCartTotal());

    itemsEl.querySelectorAll('.qty-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const id = el.dataset.id!;
        const size = el.dataset.size || undefined;
        const action = el.dataset.action;
        const item = items.find(i => i.id === id && (i.size || '') === (size || ''));
        if (!item) return;
        const newQty = action === 'increase' ? item.quantity + 1 : item.quantity - 1;
        if (newQty < 1) {
          removeFromCart(id, size);
        } else {
          updateQuantity(id, size, newQty);
        }
        renderCart();
      });
    });

    itemsEl.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        removeFromCart(el.dataset.id!, el.dataset.size || undefined);
        renderCart();
      });
    });
  }

  document.getElementById('checkout-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const statusEl = document.getElementById('form-status')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const honeypot = (document.getElementById('checkout-website') as HTMLInputElement).value;
    if (honeypot) return;

    const name = (document.getElementById('checkout-name') as HTMLInputElement).value;
    const phone = (document.getElementById('checkout-phone') as HTMLInputElement).value;
    const items = getCartItems();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    statusEl.className = 'sm:col-span-2 font-body text-sm';
    statusEl.textContent = '';

    try {
      const res = await fetch('/api/order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          itemId: items.map(i => `${i.name}${i.size ? ' (' + i.size + ')' : ''} x${i.quantity}`).join(', '),
          name,
          phone,
          quantity: items.reduce((sum, i) => sum + i.quantity, 0),
        }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.errors?.join(', ') || 'Request failed');

      clearCart();
      statusEl.className = 'sm:col-span-2 font-body text-sm text-emerald-400';
      statusEl.innerHTML = `Order received! Ref: <strong>${data.ref}</strong>. We'll have it ready for pickup.`;
      submitBtn.style.display = 'none';
      document.getElementById('cart-items')!.innerHTML = '';
      document.querySelector('#cart-content .card:first-of-type')?.setAttribute('style', 'display:none');
      window.dispatchEvent(new CustomEvent('cart-updated', { detail: [] }));
    } catch (err: any) {
      statusEl.className = 'sm:col-span-2 font-body text-sm text-brand-red';
      statusEl.textContent = err.message || 'Something went wrong. Please try again or call (337) 288-6226.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Place Order';
    }
  });

  renderCart();
</script>
