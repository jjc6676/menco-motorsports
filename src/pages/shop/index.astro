---
import Layout from '../../layouts/Layout.astro';
import { categories, products } from '../../data/products';

const shopDescription =
  'Browse diesel performance upgrades, filters, fuel system parts, and monitoring gear from Menco Motorsports.';

const allCategories = ['All', ...categories];
const formatPrice = (price: number) =>
  new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
  }).format(price);
---

<Layout title="Shop" description={shopDescription} canonical="https://menco.pages.dev/shop">
  <section class="bg-gradient-to-b from-brand-black via-brand-dark to-brand-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-brand-red">Menco Store</p>
        <h1 class="section-heading mt-4">Parts We Trust. Gear We Wear.</h1>
        <span class="red-accent-line"></span>
        <p class="section-subheading max-w-2xl">
          Shop fuel system upgrades, performance parts, filters, gauges, and Menco merch. All
          handpicked from brands we stand behind. Powerstroke, Duramax, Cummins, and everything
          else that runs diesel.
        </p>
      </div>

      <div class="mt-10 flex flex-wrap gap-3" aria-label="Product categories">
        {allCategories.map((category, index) => (
          <button
            type="button"
            data-filter={category}
            class:list={[
              'filter-btn rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.25em] transition-colors duration-200',
              index === 0
                ? 'border-brand-red bg-brand-red text-white'
                : 'border-white/15 bg-brand-dark text-brand-gray hover:border-brand-red/60 hover:text-brand-light',
            ]}
          >
            {category}
          </button>
        ))}
      </div>

      <div class="mt-12 grid gap-8 sm:grid-cols-2 xl:grid-cols-3 auto-rows-fr">
        {products.map((product) => (
          <article class="card group flex h-full flex-col overflow-hidden rounded-2xl" data-category={product.category}>
            <a href={`/shop/${product.slug}/`} class="block overflow-hidden">
              <img
                src="/favicon.svg"
                alt={product.name}
                class="h-64 w-full object-contain p-8 transition-transform duration-300 group-hover:scale-[1.03]"
                loading="lazy"
              />
            </a>

            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center justify-between gap-4">
                <span class="whitespace-nowrap text-[11px] font-semibold uppercase tracking-[0.25em] text-brand-red">
                  {product.category}
                </span>
                <span class:list={[
                  'whitespace-nowrap text-[11px] font-semibold uppercase tracking-[0.22em]',
                  product.inStock ? 'text-emerald-300' : 'text-brand-gray',
                ]}>
                  {product.inStock ? 'In Stock' : 'Backorder'}
                </span>
              </div>

              <h2 class="mt-5 text-xl leading-none text-brand-light truncate">
                <a href={`/shop/${product.slug}`} class="transition-colors hover:text-brand-red">
                  {product.name}
                </a>
              </h2>

              <p class="mt-4 flex-1 text-xs leading-5 text-brand-gray line-clamp-2">{product.description}</p>

              <div class="mt-6 flex items-end justify-between gap-4">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-gray">Price</p>
                  <p class="mt-1 text-2xl font-semibold text-white">{formatPrice(product.price)}</p>
                </div>
                <a href={`/shop/${product.slug}`} class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-red transition-colors hover:text-white">
                  View Details
                </a>
              </div>

              {product.sizes && product.sizes.length > 0 && (
                <div class="mt-4 flex items-center gap-3">
                  <span class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-gray">Size</span>
                  <select class="size-select flex-1 border border-white/10 bg-black/40 px-3 py-2 text-sm font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red" data-for={product.id}>
                    {product.sizes.map((s: string) => <option value={s}>{s}</option>)}
                  </select>
                </div>
              )}

              <button
                class:list={[
                  'add-to-cart-btn mt-4 w-full rounded-xl border px-4 py-3 text-sm font-semibold uppercase tracking-[0.25em] transition-all duration-200',
                  product.inStock
                    ? 'border-brand-red bg-brand-red text-white hover:bg-brand-redHot hover:shadow-red-glow'
                    : 'cursor-not-allowed border-white/10 bg-white/5 text-brand-gray',
                ]}
                data-id={product.id}
                data-name={product.name}
                data-price={String(Math.round(product.price * 100))}
                data-has-sizes={product.sizes ? 'true' : 'false'}
                disabled={!product.inStock}
              >
                {product.inStock ? 'Add to Cart' : 'Unavailable'}
              </button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  // Category filtering
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('article[data-category]');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'All';

      filterBtns.forEach((b) => {
        b.classList.remove('border-brand-red', 'bg-brand-red', 'text-white');
        b.classList.add('border-white/15', 'bg-brand-dark', 'text-brand-gray');
      });
      btn.classList.add('border-brand-red', 'bg-brand-red', 'text-white');
      btn.classList.remove('border-white/15', 'bg-brand-dark', 'text-brand-gray');

      cards.forEach((card) => {
        if (filter === 'All' || card.dataset.category === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  import { addToCart } from '../../lib/cart';

  document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      if (el.hasAttribute('disabled')) return;
      const id = el.dataset.id!;
      const name = el.dataset.name!;
      const price = parseInt(el.dataset.price!, 10);
      const hasSizes = el.dataset.hasSizes === 'true';

      let size: string | undefined;
      if (hasSizes) {
        const select = el.closest('article')?.querySelector(`.size-select[data-for="${id}"]`) as HTMLSelectElement;
        size = select?.value;
      }

      addToCart({ id, name, price, size });

      const original = el.textContent;
      el.textContent = 'Added!';
      setTimeout(() => { el.textContent = original; }, 1500);
    });
  });
</script>
