---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Contact Menco Motorsports for diesel repair, performance upgrades, fabrication work, and shop scheduling in Lafayette, Louisiana."
>
  <section class="border-b border-white/10 bg-gradient-to-b from-brand-dark to-brand-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <p class="font-body text-sm uppercase tracking-[0.35em] text-brand-red">Contact Menco</p>
      <h1 class="section-heading mt-4">Let’s Talk About Your Truck.</h1>
      <span class="red-accent-line"></span>
      <p class="max-w-3xl font-body text-brand-gray text-lg leading-relaxed">
        Reach out for diesel diagnostics, major repairs, performance upgrades, fabrication work, or general shop
        questions. Send the details and Menco Motorsports can follow up with next-step scheduling.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <div class="card p-6 sm:p-8 lg:p-10">
          <div class="mb-8">
            <p class="font-heading text-3xl uppercase tracking-wide text-brand-light">Request Service</p>
            <span class="red-accent-line"></span>
            <p class="font-body text-brand-gray leading-relaxed">
              Fill out the form below with your contact information, truck details, and what kind of work you need.
            </p>
          </div>

          <form
            id="contact-form"
            class="grid grid-cols-1 gap-5 sm:grid-cols-2"
          >
            <div style="display:none;">
              <label for="website-hp">Website</label>
              <input type="text" id="website-hp" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                First Name
              </span>
              <input
                type="text"
                name="first_name"
                autocomplete="given-name"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Last Name
              </span>
              <input
                type="text"
                name="last_name"
                autocomplete="family-name"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Email
              </span>
              <input
                type="email"
                name="email"
                autocomplete="email"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Phone
              </span>
              <input
                type="tel"
                name="phone"
                autocomplete="tel"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block sm:col-span-2">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Vehicle / Build Info
              </span>
              <input
                type="text"
                name="vehicle"
                placeholder="Year, make, model, engine, and any major mods"
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition placeholder:text-brand-gray/60 focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block sm:col-span-2">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Service Needed
              </span>
              <select
                name="service_needed"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              >
                <option value="">Select a service</option>
                <option value="diesel repair">Diesel Repair</option>
                <option value="diagnostics">Diagnostics</option>
                <option value="performance upgrades">Performance Upgrades</option>
                <option value="fabrication">Fabrication</option>
                <option value="maintenance">Maintenance</option>
                <option value="other">Other</option>
              </select>
            </label>

            <label class="block sm:col-span-2">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Message
              </span>
              <textarea
                name="message"
                rows="6"
                required
                placeholder="Tell us what the truck is doing, what work has already been done, and what kind of timeline you're working with."
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition placeholder:text-brand-gray/60 focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              ></textarea>
            </label>

            <div class="sm:col-span-2 flex flex-col gap-4 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
              <p class="max-w-xl font-body text-sm leading-relaxed text-brand-gray">
                Prefer to call instead? Tap the number in the contact panel and talk through your build, repair, or scheduling needs directly.
              </p>
              <button type="submit" id="submit-btn" class="btn-red w-full text-center sm:w-auto">Send Request</button>
            </div>
            <div id="form-status" class="sm:col-span-2 mt-4 font-body text-sm"></div>
          </form>
        </div>

        <aside class="space-y-6">
          <div class="card p-6 sm:p-8">
            <p class="font-heading text-3xl uppercase tracking-wide text-brand-light">Shop Information</p>
            <span class="red-accent-line"></span>
            <div class="space-y-5 font-body text-brand-gray">
              <div class="flex items-start gap-3">
                <span class="mt-1 inline-flex h-9 w-9 items-center justify-center border border-brand-red/40 bg-brand-red/10 text-brand-red">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-red">Phone</p>
                  <a href="tel:3372886226" class="mt-2 inline-block text-lg text-brand-light transition hover:text-brand-red">(337) 288-6226</a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <span class="mt-1 inline-flex h-9 w-9 items-center justify-center border border-brand-red/40 bg-brand-red/10 text-brand-red">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-red">Email</p>
                  <a href="mailto:tucksdieselservices@yahoo.com" class="mt-2 inline-block break-all text-lg text-brand-light transition hover:text-brand-red">
                    tucksdieselservices@yahoo.com
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <span class="mt-1 inline-flex h-9 w-9 items-center justify-center border border-brand-red/40 bg-brand-red/10 text-brand-red">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-red">Location</p>
                  <p class="mt-2 text-lg text-brand-light">Lafayette, LA 70507</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <span class="mt-1 inline-flex h-9 w-9 items-center justify-center border border-brand-red/40 bg-brand-red/10 text-brand-red">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-red">Hours</p>
                  <p class="mt-2 text-lg text-brand-light">Mon–Fri: 7am–5pm</p>
                  <p class="text-sm">Saturday: By appointment</p>
                </div>
              </div>
            </div>
          </div>

          <div class="card overflow-hidden">
            <div class="border-b border-white/10 p-6 sm:p-8">
              <p class="font-heading text-2xl uppercase tracking-wide text-brand-light">Visit the Shop</p>
              <p class="mt-3 font-body text-sm leading-relaxed text-brand-gray">
                A future embedded map can live in the block below when the final public-facing address and Google Maps embed are ready.
              </p>
            </div>
            <div class="relative min-h-[16rem] bg-black/60">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.08),transparent_40%),linear-gradient(180deg,rgba(10,10,10,0.15),rgba(10,10,10,0.9))]"></div>
              <div class="absolute inset-0 bg-gradient-to-br from-brand-red/20 via-transparent to-transparent"></div>
              <div class="relative flex min-h-[16rem] items-center justify-center p-6 text-center">
                <div>
                  <p class="font-heading text-3xl uppercase tracking-wide text-brand-light">Google Maps Placeholder</p>
                  <p class="mt-3 font-body text-sm leading-relaxed text-brand-gray max-w-sm">
                    Swap this panel with the final embed when location publishing is approved.
                  </p>
                </div>
              </div>

              <!--
              Google Maps embed placeholder:
              <iframe
                src="YOUR_GOOGLE_MAPS_EMBED_URL"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Menco Motorsports location map"
              ></iframe>
              -->
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const statusEl = document.getElementById('form-status')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const honeypot = (form.querySelector('[name="website"]') as HTMLInputElement)?.value;
    if (honeypot) return;

    const data = new FormData(form);
    const name = `${data.get('first_name') || ''} ${data.get('last_name') || ''}`.trim();
    const email = data.get('email') as string;
    const phone = data.get('phone') as string;
    const vehicle = data.get('vehicle') as string;
    const service = data.get('service_needed') as string;
    const message = data.get('message') as string;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    statusEl.className = 'sm:col-span-2 mt-4 font-body text-sm';
    statusEl.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name, email, phone, service,
          message: vehicle ? `Vehicle: ${vehicle}\n\n${message}` : message
        }),
      });
      const result = await res.json();
      if (!res.ok) throw new Error(result.errors?.join(', ') || 'Request failed');

      statusEl.className = 'sm:col-span-2 mt-4 font-body text-sm text-emerald-400';
      statusEl.textContent = 'Message sent! We\'ll get back to you shortly.';
      submitBtn.style.display = 'none';
      form.reset();
    } catch (err: any) {
      statusEl.className = 'sm:col-span-2 mt-4 font-body text-sm text-brand-red';
      statusEl.textContent = err.message || 'Something went wrong. Please try again or call (337) 288-6226.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Request';
    }
  });
</script>
