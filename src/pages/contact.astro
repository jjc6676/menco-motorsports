---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Contact Menco Motorsports for diesel repair, performance upgrades, fabrication work, and shop scheduling in Lafayette, Louisiana."
>
  <section class="border-b border-white/10 bg-gradient-to-b from-brand-dark to-brand-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <p class="font-body text-sm uppercase tracking-[0.35em] text-brand-red">Contact Menco</p>
      <h1 class="section-heading mt-4">Let’s Talk About Your Truck.</h1>
      <span class="red-accent-line"></span>
      <p class="max-w-3xl font-body text-brand-gray text-lg leading-relaxed">
        Reach out for diesel diagnostics, major repairs, performance upgrades, fabrication work, or general shop
        questions. Send the details and Menco Motorsports can follow up with next-step scheduling.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <div class="bg-brand-dark border border-white/10 p-6 sm:p-8 lg:p-10">
          <div class="mb-8">
            <p class="font-heading text-3xl uppercase tracking-wide text-brand-light">Request Service</p>
            <span class="red-accent-line"></span>
            <p class="font-body text-brand-gray leading-relaxed">
              Fill out the form below with your contact information, truck details, and what kind of work you need.
            </p>
          </div>

          <form
            id="contact-form"
            class="grid grid-cols-1 gap-5 sm:grid-cols-2"
          >
            <div style="display:none;">
              <label for="website-hp">Website</label>
              <input type="text" id="website-hp" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                First Name
              </span>
              <input
                type="text"
                name="first_name"
                autocomplete="given-name"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Last Name
              </span>
              <input
                type="text"
                name="last_name"
                autocomplete="family-name"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Email
              </span>
              <input
                type="email"
                name="email"
                autocomplete="email"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Phone
              </span>
              <input
                type="tel"
                name="phone"
                autocomplete="tel"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block sm:col-span-2">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Vehicle / Build Info
              </span>
              <input
                type="text"
                name="vehicle"
                placeholder="Year, make, model, engine, and any major mods"
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition placeholder:text-brand-gray/60 focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              />
            </label>

            <label class="block sm:col-span-2">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Service Needed
              </span>
              <select
                name="service_needed"
                required
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              >
                <option value="">Select a service</option>
                <option value="diesel repair">Diesel Repair</option>
                <option value="diagnostics">Diagnostics</option>
                <option value="performance upgrades">Performance Upgrades</option>
                <option value="fabrication">Fabrication</option>
                <option value="maintenance">Maintenance</option>
                <option value="other">Other</option>
              </select>
            </label>

            <label class="block sm:col-span-2">
              <span class="mb-2 block font-body text-xs font-semibold uppercase tracking-[0.28em] text-brand-gray">
                Message
              </span>
              <textarea
                name="message"
                rows="6"
                required
                placeholder="Tell us what the truck is doing, what work has already been done, and what kind of timeline you're working with."
                class="w-full border border-white/10 bg-black/40 px-4 py-3 font-body text-brand-light outline-none transition placeholder:text-brand-gray/60 focus:border-brand-red focus:ring-1 focus:ring-brand-red"
              ></textarea>
            </label>

            <div class="sm:col-span-2 flex flex-col gap-4 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
              <p class="max-w-xl font-body text-sm leading-relaxed text-brand-gray">
                Prefer to call instead? Tap the number in the contact panel and talk through your build, repair, or scheduling needs directly.
              </p>
              <button type="submit" id="submit-btn" class="btn-red w-full text-center sm:w-auto">Send Request</button>
            </div>
            <div id="form-status" class="sm:col-span-2 mt-4 font-body text-sm"></div>
          </form>
        </div>

        <aside class="space-y-6">
          <div class="bg-brand-dark border border-white/10 p-6 sm:p-8">
            <p class="font-heading text-3xl uppercase tracking-wide text-brand-light">Shop Information</p>
            <span class="red-accent-line"></span>
            <div class="space-y-5 font-body">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-red">Phone</p>
                <a href="tel:3372886226" class="mt-2 inline-block text-lg text-brand-light transition hover:text-brand-red">(337) 288-6226</a>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-red">Email</p>
                <a href="mailto:tucksdieselservices@yahoo.com" class="mt-2 inline-block break-all text-lg text-brand-light transition hover:text-brand-red">tucksdieselservices@yahoo.com</a>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-red">Location</p>
                <p class="mt-2 text-lg text-brand-light">Lafayette, LA 70507</p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-brand-red">Hours</p>
                <p class="mt-2 text-lg text-brand-light">Mon–Fri: 7am–5pm</p>
                <p class="text-sm text-brand-gray">Saturday: By appointment</p>
              </div>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const statusEl = document.getElementById('form-status')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const honeypot = (form.querySelector('[name="website"]') as HTMLInputElement)?.value;
    if (honeypot) return;

    const data = new FormData(form);
    const name = `${data.get('first_name') || ''} ${data.get('last_name') || ''}`.trim();
    const email = data.get('email') as string;
    const phone = data.get('phone') as string;
    const vehicle = data.get('vehicle') as string;
    const service = data.get('service_needed') as string;
    const message = data.get('message') as string;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    statusEl.className = 'sm:col-span-2 mt-4 font-body text-sm';
    statusEl.textContent = '';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name, email, phone, service,
          message: vehicle ? `Vehicle: ${vehicle}\n\n${message}` : message
        }),
      });
      const result = await res.json();
      if (!res.ok) throw new Error(result.errors?.join(', ') || 'Request failed');

      statusEl.className = 'sm:col-span-2 mt-4 font-body text-sm text-emerald-400';
      statusEl.textContent = 'Message sent! We\'ll get back to you shortly.';
      submitBtn.style.display = 'none';
      form.reset();
    } catch (err: any) {
      statusEl.className = 'sm:col-span-2 mt-4 font-body text-sm text-brand-red';
      statusEl.textContent = err.message || 'Something went wrong. Please try again or call (337) 288-6226.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Request';
    }
  });
</script>
