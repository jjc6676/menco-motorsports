---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Diesel Diagnostics',
    description:
      'Accurate troubleshooting for warning lights, rough running, hard starts, power loss, fuel-system concerns, and repeat issues that have not been solved correctly the first time.',
    points: ['Scan-tool based fault tracing', 'Electrical and drivability diagnosis', 'Repair plans built around root cause'],
  },
  {
    title: 'Repair & Reliability Work',
    description:
      'Dependable repair work for diesel pickups and work trucks that cannot afford unnecessary downtime. We focus on quality, clarity, and repairs that make sense for the truck.',
    points: ['Engine-related diesel repairs', 'Supporting system service and replacement', 'Recommendations prioritized by urgency and use case'],
  },
  {
    title: 'Performance Upgrades',
    description:
      'Thoughtful performance improvements for owners who want stronger response, better towing confidence, or a more complete build without sacrificing a smart foundation.',
    points: ['Airflow and turbo supporting upgrades', 'Fueling and monitoring recommendations', 'Upgrade paths matched to goals and budget'],
  },
  {
    title: 'Powerstroke Service',
    description:
      'Ford diesel support for owners who need a shop that understands common platform issues, reliable repair strategy, and practical improvement planning.',
    points: ['6.0 and 6.7 Powerstroke', 'Repair-first problem solving', 'Performance guidance with reliability in mind'],
  },
  {
    title: 'Duramax Service',
    description:
      'GM diesel diagnostics, repair, and upgrade consultation for trucks used for hauling, daily driving, and hard work in real conditions.',
    points: ['LB7 through L5P platform support', 'Driveability and fuel-system attention', 'Street, tow, and work-focused setups'],
  },
  {
    title: 'Cummins Service',
    description:
      'Ram diesel expertise for owners looking to restore confidence, solve nagging problems, or build a truck with dependable supporting systems.',
    points: ['Common rail platform familiarity', 'Work-truck and towing priorities', 'Balanced planning for repairs and upgrades'],
  },
];

const processSteps = [
  {
    title: '1. Talk through the truck',
    description: 'Start with the platform, symptoms, current setup, and how the truck is actually used day to day.',
  },
  {
    title: '2. Diagnose before guessing',
    description: 'Use a methodical diesel-focused process to identify the issue instead of throwing parts at the problem.',
  },
  {
    title: '3. Prioritize the right work',
    description: 'Separate immediate needs from future upgrades so owners can make informed decisions with confidence.',
  },
  {
    title: '4. Build for the real goal',
    description: 'Whether that means reliability, towing, response, or performance, the final recommendation should fit the truck’s job.',
  },
];
---

<Layout
  title="Services"
  description="Explore diesel diagnostics, repair, and performance services from Menco Motorsports for Powerstroke, Duramax, and Cummins trucks in Lafayette, LA."
>
  <section class="relative overflow-hidden border-b border-white/10 bg-brand-black">
    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(204,0,0,0.16),transparent_40%),repeating-linear-gradient(0deg,rgba(255,255,255,0.04)_0,rgba(255,255,255,0.04)_1px,transparent_1px,transparent_52px)] opacity-70"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-3xl">
        <p class="font-body text-sm uppercase tracking-[0.35em] text-brand-red">Services</p>
        <h1 class="mt-4 font-heading text-6xl md:text-7xl leading-none uppercase text-brand-light">
          Diesel service with a practical performance mindset
        </h1>
        <span class="red-accent-line"></span>
        <p class="text-lg text-brand-gray leading-relaxed max-w-2xl">
          Menco Motorsports provides diesel diagnostics, repair, and upgrade planning for truck owners who need real answers and reliable results. We focus on Powerstroke, Duramax, and Cummins platforms with work-first discipline and performance knowledge.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-dark/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="font-body uppercase tracking-[0.3em] text-sm text-brand-red">What we do</p>
        <h2 class="section-heading mt-4">Core shop services</h2>
        <p class="section-subheading">
          Every service starts with understanding what the truck needs now and what will actually serve the owner long term.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {services.map((service) => (
          <article class="bg-brand-dark border border-white/10 p-6 h-full flex flex-col">
            <h3 class="font-heading text-3xl text-brand-light uppercase">{service.title}</h3>
            <span class="red-accent-line"></span>
            <p class="text-brand-gray leading-relaxed flex-1">{service.description}</p>
            <ul class="mt-6 space-y-2 text-sm text-brand-light/90">
              {service.points.map((point) => (
                <li class="flex gap-3">
                  <span class="mt-1.5 h-2 w-2 rounded-full bg-brand-red shrink-0"></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-black border-y border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-10 items-start">
        <div>
          <p class="font-body uppercase tracking-[0.3em] text-sm text-brand-red">How Menco works</p>
          <h2 class="section-heading mt-4">A better process for serious truck owners</h2>
          <p class="section-subheading max-w-xl">
            Diesel service should not feel like guesswork. We keep the process straightforward, informed, and centered on the actual job your truck has to do.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {processSteps.map((step) => (
            <article class="bg-brand-dark border border-white/10 p-6 h-full">
              <h3 class="font-heading text-2xl text-brand-light uppercase">{step.title}</h3>
              <p class="mt-4 text-brand-gray leading-relaxed text-sm md:text-base">{step.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-dark/70">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-body uppercase tracking-[0.3em] text-sm text-brand-red">Need help with your truck?</p>
      <h2 class="section-heading mt-4">Tell us what your diesel is doing</h2>
      <p class="section-subheading max-w-3xl mx-auto">
        If your truck has a persistent issue, needs a smarter repair path, or you are planning upgrades the right way, Menco Motorsports is ready to help you sort out the next move.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact" class="btn-red">Request a Quote</a>
        <a href="/about" class="btn-outline">Learn About Menco</a>
      </div>
    </div>
  </section>
</Layout>
