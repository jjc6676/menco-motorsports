---
import Layout from '../layouts/Layout.astro';

const galleryItems = [
  {
    title: '2018 Ford 6.7L — DCR Build',
    category: 'Showcase Build',
    description: 'This 2018 Ford F-250 6.7L came in for a full reliability and performance build. Every system that needed attention got it. Done right.',
    bullets: ['DCR conversion', 'CCV upgrade', 'Select power mods', 'New bearing & hub assemblies'],
    height: 'h-[26rem]',
    objectPosition: 'object-bottom',
    image: '/images/gallery/2018%20Ford%206.7L/truck-exterior.jpg',
    images: [
      '/images/gallery/2018%20Ford%206.7L/truck-exterior.jpg',
      '/images/gallery/2018%20Ford%206.7L/engine-bay.jpg',
      '/images/gallery/2018%20Ford%206.7L/turbo-closeup.jpg',
    ],
  },
  {
    title: '2019 F-250 — Prevention Kit',
    category: 'Preventative Maintenance',
    description: 'This 2019 F-250 came in for a full preventative package. Intake cleaned, filter replaced, and the CP4 protected. Ready for many more miles.',
    bullets: ['S&S Disaster Prevention Kit', 'New CCV filter', 'Full intake cleaning'],
    height: 'h-[26rem]',
    image: '/images/gallery/2019%20F-250/truck-exterior.jpg',
    images: [
      '/images/gallery/2019%20F-250/truck-exterior.jpg',
      '/images/gallery/2019%20F-250/ccv-filter.jpg',
      '/images/gallery/2019%20F-250/intake-clean.jpg',
      '/images/gallery/2019%20F-250/intake-component.jpg',
      '/images/gallery/2019%20F-250/intake-before.jpg',
      '/images/gallery/2019%20F-250/intake-dirty.jpg',
    ],
  },
  {
    title: 'CAT D4 — Fuel Pump',
    category: 'Heavy Equipment',
    description: 'Service call out in the field — fuel pump replacement on a CAT D4. Back up and running strong.',
    height: 'h-[26rem]',
    image: '/images/gallery/CAT%20D4/cat-d4-field.jpg',
    images: [
      '/images/gallery/CAT%20D4/cat-d4-field.jpg',
      '/images/gallery/CAT%20D4/fuel-pump-repair.jpg',
    ],
  },
  {
    title: 'Fuel Systems Finished Up',
    category: 'Fuel System',
    description: 'A few trucks wrapped up with complete fuel system work — from diagnostics and parts to final testing and calibration. Done right.',
    bullets: ['Professional diagnostics', 'OEM & performance parts', 'Clean, precise installations', 'Quick turnaround times'],
    height: 'h-[26rem]',
    image: '/images/gallery/Couple%20Fuel%20Systems%20Finished%20Up/red-ford-exterior.jpg',
    images: [
      '/images/gallery/Couple%20Fuel%20Systems%20Finished%20Up/red-ford-exterior.jpg',
      '/images/gallery/Couple%20Fuel%20Systems%20Finished%20Up/black-chevy-exterior.jpg',
      '/images/gallery/Couple%20Fuel%20Systems%20Finished%20Up/engine-components.jpg',
      '/images/gallery/Couple%20Fuel%20Systems%20Finished%20Up/fuel-system-parts.jpg',
    ],
  },
  {
    title: 'Ford Bronco — Running Boards',
    category: 'Accessories',
    description: 'Ford Bronco finished up with a set of electric running boards installed. Sleek, modern, and done right.',
    height: 'h-[26rem]',
    image: '/images/gallery/FordBronco/bronco-exterior.jpg',
    images: ['/images/gallery/FordBronco/bronco-exterior.jpg'],
  },
  {
    title: 'Knocking Out Jobs',
    category: 'Shop Work',
    description: 'Knocking out jobs and delivering quality work every single day. From start to finish, done with craftsmanship, efficiency, and attention to detail.',
    height: 'h-[26rem]',
    objectPosition: 'object-center',
    image: '/images/gallery/Knocking%20out%20jobs/black-ford.jpg',
    images: [
      '/images/gallery/Knocking%20out%20jobs/black-ford.jpg',
      '/images/gallery/Knocking%20out%20jobs/white-chevy.jpg',
      '/images/gallery/Knocking%20out%20jobs/silver-truck.jpg',
      '/images/gallery/Knocking%20out%20jobs/service-van.jpg',
      '/images/gallery/Knocking%20out%20jobs/gray-ford.jpg',
      '/images/gallery/Knocking%20out%20jobs/fleet-shot.jpg',
    ],
  },
];
---

<Layout
  title="Gallery"
  description="Browse the Menco Motorsports gallery featuring diesel builds, fabrication details, shop work, and performance truck projects."
>
  <section class="border-b border-white/10 bg-gradient-to-b from-brand-dark to-brand-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <p class="font-body text-sm uppercase tracking-[0.35em] text-brand-red">Menco Gallery</p>
      <h1 class="section-heading mt-4">Built in the Shop. Proven on the Road.</h1>
      <span class="red-accent-line"></span>
      <p class="max-w-3xl font-body text-brand-gray text-lg leading-relaxed">
        A quick look at the work, attitude, and mechanical detail behind Menco Motorsports. From fuel system overhauls
        to full performance builds, this is what happens in the shop every day.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
        {galleryItems.map((item) => (
          <figure class="group card overflow-hidden rounded-sm">
            <button
              type="button"
              class="gallery-card w-full h-full flex flex-col bg-brand-dark text-left"
              data-gallery-trigger
              data-title={item.title}
              data-category={item.category}
              data-description={item.description}
              data-bullets={item.bullets ? JSON.stringify(item.bullets) : ''}
              data-image={item.image}
              data-images={item.images ? JSON.stringify(item.images) : ''}
              aria-label={`Open ${item.title} in lightbox`}
            >
              <div class={`relative ${item.height} w-full overflow-hidden flex-shrink-0`}>
                <img
                  src={item.image}
                  alt={`${item.title} — ${item.category}`}
                  loading="lazy"
                  class={`absolute inset-0 h-full w-full object-cover ${item.objectPosition ?? 'object-bottom'} transition-transform duration-500 ease-out group-hover:scale-[1.04]`}
                />
                <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,10,10,0.05)_0%,rgba(10,10,10,0.3)_100%)]"></div>
              </div>
              <div class="flex-1 w-full border-t border-white/10 bg-black/50 p-5 backdrop-blur-sm transition duration-200 group-hover:bg-black/65">
                <p class="font-body text-xs uppercase tracking-[0.28em] text-brand-red">{item.category}</p>
                <figcaption class="mt-2 font-heading text-2xl uppercase tracking-wide text-brand-light">
                  {item.title}
                </figcaption>
                {item.bullets ? (
                  <ul class="mt-2 space-y-1 font-body text-sm text-brand-gray">
                    {item.bullets.map((b) => (
                      <li class="flex items-center gap-2">
                        <span class="inline-block h-1 w-1 flex-shrink-0 rounded-full bg-brand-red"></span>
                        {b}
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="mt-2 font-body text-sm leading-relaxed text-brand-gray">{item.description}</p>
                )}
              </div>
            </button>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <div
    id="gallery-lightbox"
    class="fixed inset-0 z-[70] hidden items-center justify-center bg-black/90 px-4 py-8"
    aria-hidden="true"
  >
    <div class="absolute inset-0" data-lightbox-close></div>
    <div class="relative z-10 w-full max-w-4xl border border-white/10 bg-brand-dark shadow-2xl shadow-black/60">
      <button
        type="button"
        class="absolute right-3 top-3 z-20 inline-flex h-11 w-11 items-center justify-center border border-white/10 bg-black/70 text-brand-light transition hover:border-brand-red hover:text-brand-red"
        data-lightbox-close
        aria-label="Close gallery lightbox"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="grid gap-0 lg:grid-cols-[1.25fr_0.75fr]">
        <div class="relative min-h-[24rem] overflow-hidden bg-black">
          <img id="lightbox-image" src="" alt="" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,10,10,0.05)_0%,rgba(10,10,10,0.25)_100%)]"></div>
          <div class="absolute left-6 top-6 border border-white/10 bg-black/60 px-3 py-2 font-body text-[0.68rem] uppercase tracking-[0.3em] text-brand-light/70">
            Gallery Preview
          </div>
        </div>

        <div class="flex flex-col justify-between border-t border-white/10 p-6 lg:border-l lg:border-t-0">
          <div>
            <p id="lightbox-category" class="font-body text-xs uppercase tracking-[0.3em] text-brand-red"></p>
            <p id="lightbox-title" class="mt-2 font-heading text-2xl uppercase tracking-wide text-brand-light"></p>
            <span class="red-accent-line"></span>
            <ul id="lightbox-bullets" class="hidden mb-4 space-y-1.5 font-body text-sm text-brand-gray"></ul>
            <p id="lightbox-description" class="font-body text-base leading-relaxed text-brand-gray"></p>

            <div id="lightbox-thumbnails" class="hidden mt-6 flex gap-2 flex-wrap"></div>
          </div>

          <div class="mt-8 border-t border-white/10 pt-6">
            <a href="/contact" class="btn-red w-full text-center sm:w-auto">Book Your Build</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const lightbox = document.getElementById('gallery-lightbox');
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxCategory = document.getElementById('lightbox-category');
    const lightboxDescription = document.getElementById('lightbox-description');
    const lightboxBullets = document.getElementById('lightbox-bullets');
    const lightboxThumbnails = document.getElementById('lightbox-thumbnails');
    const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement | null;
    const triggers = document.querySelectorAll('[data-gallery-trigger]');
    const closers = document.querySelectorAll('[data-lightbox-close]');
    let previousActiveElement: HTMLElement | null = null;

    const setActiveThumb = (thumbs: HTMLButtonElement[], active: HTMLButtonElement) => {
      thumbs.forEach((t) => t.classList.remove('border-brand-red', 'opacity-100'));
      thumbs.forEach((t) => t.classList.add('border-white/20', 'opacity-60'));
      active.classList.remove('border-white/20', 'opacity-60');
      active.classList.add('border-brand-red', 'opacity-100');
    };

    const openLightbox = (trigger: HTMLElement | null) => {
      if (!(trigger instanceof HTMLElement) || !lightbox) return;

      previousActiveElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      if (lightboxTitle) lightboxTitle.textContent = trigger.dataset.title ?? '';
      if (lightboxCategory) lightboxCategory.textContent = trigger.dataset.category ?? '';
      if (lightboxDescription) lightboxDescription.textContent = trigger.dataset.description ?? '';

      if (lightboxBullets) {
        const raw = trigger.dataset.bullets ?? '';
        const bullets: string[] = raw ? JSON.parse(raw) : [];
        if (bullets.length > 0) {
          lightboxBullets.innerHTML = bullets
            .map((b) => `<li class="flex items-center gap-2"><span class="inline-block h-1 w-1 flex-shrink-0 rounded-full bg-brand-red"></span>${b}</li>`)
            .join('');
          lightboxBullets.classList.remove('hidden');
        } else {
          lightboxBullets.innerHTML = '';
          lightboxBullets.classList.add('hidden');
        }
      }

      const primaryImage = trigger.dataset.image ?? '';
      if (lightboxImage) {
        lightboxImage.src = primaryImage;
        lightboxImage.alt = trigger.dataset.title ?? '';
      }

      if (lightboxThumbnails) {
        const rawImages = trigger.dataset.images ?? '';
        const images: string[] = rawImages ? JSON.parse(rawImages) : [];
        if (images.length > 1) {
          const thumbButtons: HTMLButtonElement[] = images.map((src) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'h-16 w-20 flex-shrink-0 overflow-hidden border-2 border-white/20 opacity-60 transition hover:opacity-100 hover:border-brand-red';
            btn.innerHTML = `<img src="${src}" alt="" class="h-full w-full object-cover" loading="lazy" />`;
            btn.addEventListener('click', () => {
              if (lightboxImage) {
                lightboxImage.src = src;
                lightboxImage.alt = trigger.dataset.title ?? '';
              }
              setActiveThumb(thumbButtons, btn);
            });
            return btn;
          });
          lightboxThumbnails.innerHTML = '';
          thumbButtons.forEach((btn) => lightboxThumbnails.appendChild(btn));
          setActiveThumb(thumbButtons, thumbButtons[0]);
          lightboxThumbnails.classList.remove('hidden');
        } else {
          lightboxThumbnails.innerHTML = '';
          lightboxThumbnails.classList.add('hidden');
        }
      }

      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      const closeButton = lightbox.querySelector('button[data-lightbox-close]');
      if (closeButton instanceof HTMLElement) closeButton.focus();
    };

    const closeLightbox = () => {
      if (!lightbox) return;
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      previousActiveElement?.focus();
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => openLightbox(trigger instanceof HTMLElement ? trigger : null));
    });

    closers.forEach((closer) => {
      closer.addEventListener('click', closeLightbox);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && lightbox && !lightbox.classList.contains('hidden')) {
        closeLightbox();
      }
    });
  </script>
</Layout>
