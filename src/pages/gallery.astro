---
import Layout from '../layouts/Layout.astro';

// Placeholder photos via picsum.photos (deterministic via seed).
// Swap each `image` URL with a real shop photo when media is ready.
const galleryItems = [
  {
    title: 'Fuel System Upgrade',
    category: 'Powerstroke Performance',
    description: 'Ford F-250 6.7L Powerstroke fuel system upgrade with high-flow injectors and upgraded lines for reliable power.',
    height: 'h-72',
    image: 'https://picsum.photos/seed/menco-1/900/700',
  },
  {
    title: 'Disaster Prevention Kit',
    category: 'Preventative Maintenance',
    description: 'S&S Disaster Prevention Kit installation to protect against catastrophic CP4 pump failure on 6.7L Powerstrokes.',
    height: 'h-96',
    image: 'https://picsum.photos/seed/menco-2/900/900',
  },
  {
    title: 'Misfire Diagnostics',
    category: 'Precision Diagnostics',
    description: 'Cylinder misfire diagnostics on Powerstroke using factory scan tools and in-house testing procedures.',
    height: 'h-80',
    image: 'https://picsum.photos/seed/menco-3/900/800',
  },
  {
    title: 'DCR Pump Conversion',
    category: 'Fuel System',
    description: 'DCR pump conversion completed, eliminating the factory CP4 and upgrading to a proven gear-driven design.',
    height: 'h-[26rem]',
    image: 'https://picsum.photos/seed/menco-4/900/1100',
  },
  {
    title: 'CCV Upgrade',
    category: 'Engine Upgrades',
    description: 'CCV upgrade on Ford diesel to improve crankcase ventilation and reduce oil contamination in the intake system.',
    height: 'h-64',
    image: 'https://picsum.photos/seed/menco-5/900/650',
  },
  {
    title: 'Hub & Bearing Replacement',
    category: 'Steering & Suspension',
    description: 'Front end hub and bearing replacement on a Super Duty for tight, rattle-free steering and safe towing.',
    height: 'h-[22rem]',
    image: 'https://picsum.photos/seed/menco-6/900/950',
  },
  {
    title: 'Turbo System Service',
    category: 'Turbo & Intake',
    description: 'Turbo system service on 6.7L including up-pipe inspection, wastegate check, and boost leak testing.',
    height: 'h-72',
    image: 'https://picsum.photos/seed/menco-7/900/700',
  },
  {
    title: 'Injector & Valve Cover Reseal',
    category: 'Major Repairs',
    description: 'Injector replacement and valve cover reseal to stop oil leaks and restore proper combustion across all eight cylinders.',
    height: 'h-[22rem]',
    image: 'https://picsum.photos/seed/menco-8/900/950',
  },
  {
    title: 'Electrical Diagnostic Setup',
    category: 'Diagnostics',
    description: 'Full electrical diagnostic setup with breakout boxes and wiring harness testing on a late-model Super Duty.',
    height: 'h-60',
    image: 'https://picsum.photos/seed/menco-9/900/600',
  },
  {
    title: '2018 F-250 Performance Build',
    category: 'Showcase Build',
    description: '2018 F-250 performance build complete with tuning, exhaust, intake, and fuel system upgrades for serious towing power.',
    height: 'h-72',
    image: 'https://picsum.photos/seed/menco-10/900/700',
  },
  {
    title: 'Engine Bay Fuel Repair',
    category: 'Fuel System',
    description: 'Diesel engine bay during fuel system repair showing line routing, filter placement, and pump access.',
    height: 'h-80',
    image: 'https://picsum.photos/seed/menco-11/900/800',
  },
  {
    title: 'Completed Build Rollout',
    category: 'Finished Work',
    description: 'Completed truck leaving the shop after a full fuel system overhaul, ready for the road and heavy loads.',
    height: 'h-[22rem]',
    image: 'https://picsum.photos/seed/menco-12/900/950',
  },
];
---

<Layout
  title="Gallery"
  description="Browse the Menco Motorsports gallery featuring diesel builds, fabrication details, shop work, and performance truck projects."
>
  <section class="border-b border-white/10 bg-gradient-to-b from-brand-dark to-brand-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <p class="font-body text-sm uppercase tracking-[0.35em] text-brand-red">Menco Gallery</p>
      <h1 class="section-heading mt-4">Built in the Shop. Proven on the Road.</h1>
      <span class="red-accent-line"></span>
      <p class="max-w-3xl font-body text-brand-gray text-lg leading-relaxed">
        A quick look at the work, attitude, and mechanical detail behind Menco Motorsports. From fuel system overhauls
        to full performance builds, this is what happens in the shop every day.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="columns-1 gap-6 sm:columns-2 xl:columns-3 [column-fill:_balance]">
        {galleryItems.map((item, index) => (
          <figure class="group card relative mb-6 break-inside-avoid overflow-hidden rounded-sm">
            <button
              type="button"
              class={`gallery-card ${item.height} relative flex w-full items-end overflow-hidden bg-brand-dark text-left`}
              data-gallery-trigger
              data-title={item.title}
              data-category={item.category}
              data-description={item.description}
              data-image={item.image}
              aria-label={`Open ${item.title} in lightbox`}
            >
              <img
                src={item.image}
                alt={`${item.title} — ${item.category}`}
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04]"
              />
              <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,10,10,0.25)_0%,rgba(10,10,10,0.55)_55%,rgba(10,10,10,0.92)_100%)]"></div>
              <div class="absolute inset-0 opacity-60 mix-blend-multiply bg-[radial-gradient(circle_at_top_right,rgba(204,0,0,0.18),transparent_50%)]"></div>
              <div class="absolute left-4 top-4 flex items-center gap-2 text-[0.7rem] font-semibold uppercase tracking-[0.32em] text-brand-light/70">
                <span class="inline-block h-px w-8 bg-brand-red"></span>
                #{String(index + 1).padStart(2, '0')}
              </div>
              <div class="relative z-10 w-full border-t border-white/10 bg-black/50 p-5 backdrop-blur-sm transition duration-200 group-hover:bg-black/65">
                <p class="font-body text-xs uppercase tracking-[0.28em] text-brand-red">{item.category}</p>
                <figcaption class="mt-2 font-heading text-2xl uppercase tracking-wide text-brand-light">
                  {item.title}
                </figcaption>
                <p class="mt-2 font-body text-sm leading-relaxed text-brand-gray">{item.description}</p>
              </div>
            </button>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <div
    id="gallery-lightbox"
    class="fixed inset-0 z-[70] hidden items-center justify-center bg-black/90 px-4 py-8"
    aria-hidden="true"
  >
    <div class="absolute inset-0" data-lightbox-close></div>
    <div class="relative z-10 w-full max-w-4xl border border-white/10 bg-brand-dark shadow-2xl shadow-black/60">
      <button
        type="button"
        class="absolute right-3 top-3 z-20 inline-flex h-11 w-11 items-center justify-center border border-white/10 bg-black/70 text-brand-light transition hover:border-brand-red hover:text-brand-red"
        data-lightbox-close
        aria-label="Close gallery lightbox"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="grid gap-0 lg:grid-cols-[1.25fr_0.75fr]">
        <div class="relative min-h-[24rem] overflow-hidden bg-black">
          <img id="lightbox-image" src="" alt="" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,10,10,0.15)_0%,rgba(10,10,10,0.55)_60%,rgba(10,10,10,0.92)_100%)]"></div>
          <div class="absolute inset-0 bg-gradient-to-br from-brand-red/15 via-transparent to-black/40"></div>
          <div class="absolute left-6 top-6 border border-white/10 bg-black/60 px-3 py-2 font-body text-[0.68rem] uppercase tracking-[0.3em] text-brand-light/70">
            Gallery Preview
          </div>
          <div class="absolute bottom-6 left-6 right-6 border-t border-white/10 pt-4">
            <p id="lightbox-category" class="font-body text-xs uppercase tracking-[0.3em] text-brand-red"></p>
            <p id="lightbox-title" class="mt-2 font-heading text-4xl uppercase tracking-wide text-brand-light"></p>
          </div>
        </div>

        <div class="flex flex-col justify-between border-t border-white/10 p-6 lg:border-l lg:border-t-0">
          <div>
            <p class="font-heading text-2xl uppercase tracking-wide text-brand-light">Project Notes</p>
            <span class="red-accent-line"></span>
            <p id="lightbox-description" class="font-body text-base leading-relaxed text-brand-gray"></p>
          </div>

          <div class="mt-8 space-y-4 border-t border-white/10 pt-6 font-body text-sm text-brand-gray">
            <p>
              Need a real photo set here? Replace each placeholder card with final media assets and keep the same captions,
              categories, and lightbox structure.
            </p>
            <a href="/contact" class="btn-red w-full text-center sm:w-auto">Book Your Build</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const lightbox = document.getElementById('gallery-lightbox');
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxCategory = document.getElementById('lightbox-category');
    const lightboxDescription = document.getElementById('lightbox-description');
    const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement | null;
    const triggers = document.querySelectorAll('[data-gallery-trigger]');
    const closers = document.querySelectorAll('[data-lightbox-close]');
    let previousActiveElement: HTMLElement | null = null;

    const openLightbox = (trigger: HTMLElement | null) => {
      if (!(trigger instanceof HTMLElement) || !lightbox) return;

      previousActiveElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      if (lightboxTitle) lightboxTitle.textContent = trigger.dataset.title ?? '';
      if (lightboxCategory) lightboxCategory.textContent = trigger.dataset.category ?? '';
      if (lightboxDescription) lightboxDescription.textContent = trigger.dataset.description ?? '';
      if (lightboxImage) {
        lightboxImage.src = trigger.dataset.image ?? '';
        lightboxImage.alt = trigger.dataset.title ?? '';
      }

      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      const closeButton = lightbox.querySelector('button[data-lightbox-close]');
      if (closeButton instanceof HTMLElement) closeButton.focus();
    };

    const closeLightbox = () => {
      if (!lightbox) return;
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      previousActiveElement?.focus();
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => openLightbox(trigger instanceof HTMLElement ? trigger : null));
    });

    closers.forEach((closer) => {
      closer.addEventListener('click', closeLightbox);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && lightbox && !lightbox.classList.contains('hidden')) {
        closeLightbox();
      }
    });
  </script>
</Layout>
