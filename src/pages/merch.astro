---
import Base from '../layouts/Base.astro';
import merchData from '../data/merch.json';
---

<Base title="Merch" description="Rep the Menco Motorsports brand. Order online and pick up at the shop in Lafayette, LA.">
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-line"></div>
        <h1>Merch</h1>
        <p>Rep the brand. Order online, pick up at the shop.</p>
      </div>

      <div class="merch-grid">
        {merchData.map((item: any) => (
          <div class="merch-card">
            <div class="merch-photo">
              <span>{item.name}</span>
            </div>
            <div class="merch-info">
              <h3>{item.name}</h3>
              <p class="merch-price">${(item.price / 100).toFixed(2)}</p>
              {item.sizes && item.sizes.length > 0 && (
                <div class="merch-sizes">
                  <label class="size-label">Size:</label>
                  <select class="size-select" data-item-id={item.id}>
                    {item.sizes.map((size: string) => (
                      <option value={size}>{size}</option>
                    ))}
                  </select>
                </div>
              )}
              <p class="merch-desc">{item.description}</p>
              <button
                class="btn btn-ghost add-to-cart-btn"
                data-id={item.id}
                data-name={item.name}
                data-price={item.price}
                data-has-sizes={item.sizes ? 'true' : 'false'}
              >
                Add to Cart
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  import { addToCart } from '../lib/cart';

  document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const id = el.dataset.id!;
      const name = el.dataset.name!;
      const price = parseInt(el.dataset.price!, 10);
      const hasSizes = el.dataset.hasSizes === 'true';

      let size: string | undefined;
      if (hasSizes) {
        const select = el.closest('.merch-card')?.querySelector('.size-select') as HTMLSelectElement;
        size = select?.value;
      }

      addToCart({ id, name, price, size });

      // Visual feedback
      const original = el.textContent;
      el.textContent = 'Added!';
      el.classList.add('added');
      setTimeout(() => {
        el.textContent = original;
        el.classList.remove('added');
      }, 1500);
    });
  });
</script>

<style>
  .merch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .merch-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s;
  }
  .merch-card:hover {
    border-color: var(--accent);
  }

  .merch-photo {
    aspect-ratio: 1 / 1;
    background: var(--bg-elevated);
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--border);
  }
  .merch-photo span {
    color: var(--text-muted);
    font-size: 14px;
  }

  .merch-info {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .merch-info h3 {
    font-family: var(--font-display);
    color: var(--text-primary);
    font-size: 20px;
    margin-bottom: 8px;
  }

  .merch-price {
    color: var(--accent-accessible);
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .merch-sizes {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .size-label {
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
  }
  .size-select {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 14px;
    padding: 6px 12px;
    border-radius: 0;
    cursor: pointer;
    -webkit-appearance: none;
  }
  .size-select:focus {
    border-color: var(--accent);
    outline: 2px solid var(--accent-accessible);
    outline-offset: 2px;
  }

  .merch-desc {
    color: var(--text-body);
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .merch-info .btn {
    margin-top: auto;
    align-self: flex-start;
  }

  .merch-info .btn.added {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  @media (max-width: 1024px) {
    .merch-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .merch-grid { grid-template-columns: 1fr; }
  }
</style>
